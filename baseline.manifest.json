{
  "$description": "Contrato legível por máquina do baseline-ui. Descreve cada componente — partes, variantes, estados e tokens consumidos — para que uma ferramenta (script, MCP do Figma, plugin) consiga reconstruir a biblioteca como componentes/Variables no Figma sem ler o código-fonte. Mantido à mão junto com cada componente; o build falha se ele divergir do que src/ exporta (scripts/check-manifest.mjs). Ver ADR 0005 e docs/figma/mapeamento-figma.md.",
  "name": "baseline-ui",
  "version": "0.3.0",
  "conventions": {
    "cssVarPrefix": "--bl-",
    "cssClassPrefix": "bl-",
    "variantAttributePrefix": "data-bl-",
    "tokens": {
      "format": "w3c-design-tokens-draft",
      "files": {
        "primitives": "tokens/primitives.json",
        "semantic": {
          "light": "tokens/semantic.light.json",
          "dark": "tokens/semantic.dark.json"
        }
      }
    }
  },
  "components": {
    "Button": {
      "kind": "single",
      "base": "@base-ui/react/button",
      "cssClass": "bl-button",
      "props": {
        "variant": {
          "values": ["solid", "outline", "ghost", "danger"],
          "default": "solid",
          "dataAttribute": "data-bl-variant"
        },
        "size": {
          "values": ["sm", "md", "lg"],
          "default": "md",
          "dataAttribute": "data-bl-size"
        }
      },
      "states": ["hover", "focus-visible", "disabled"],
      "tokens": [
        "color.accent", "color.accent-text", "color.text", "color.border-strong",
        "color.bg-subtle", "color.danger", "color.danger-text",
        "space.1", "space.2", "space.3", "space.4", "space.5",
        "radius.md", "font.sans", "font-size.sm", "font-size.md",
        "font-size.lg", "font-weight.medium"
      ]
    },
    "Dialog": {
      "kind": "compound",
      "base": "@base-ui/react/dialog",
      "parts": {
        "Root": { "styled": false },
        "Trigger": { "styled": false },
        "Portal": { "styled": false },
        "Close": { "styled": false },
        "Backdrop": { "styled": true, "cssClass": "bl-dialog-backdrop" },
        "Popup": { "styled": true, "cssClass": "bl-dialog-popup" },
        "Title": { "styled": true, "cssClass": "bl-dialog-title" },
        "Description": { "styled": true, "cssClass": "bl-dialog-description" },
        "Actions": { "styled": true, "cssClass": "bl-dialog-actions", "note": "parte própria do baseline-ui, não existe no Base UI" }
      },
      "states": ["open", "starting-style", "ending-style"],
      "tokens": [
        "color.bg", "color.text", "color.text-muted", "color.border",
        "radius.lg", "shadow.popup", "space.2", "space.4", "space.5",
        "font.sans", "font-size.md", "font-size.lg", "font-weight.semibold"
      ]
    },
    "Field": {
      "kind": "compound",
      "base": "@base-ui/react/field",
      "parts": {
        "Root": { "styled": true, "cssClass": "bl-field" },
        "Label": { "styled": true, "cssClass": "bl-field-label" },
        "Control": { "styled": true, "cssClass": "bl-field-control" },
        "Description": { "styled": true, "cssClass": "bl-field-description" },
        "Error": { "styled": true, "cssClass": "bl-field-error" },
        "Validity": { "styled": false }
      },
      "states": ["focus-visible", "invalid", "disabled"],
      "tokens": [
        "color.bg", "color.bg-subtle", "color.text", "color.text-muted",
        "color.border-strong", "color.accent", "color.danger",
        "space.2", "space.3", "radius.md",
        "font.sans", "font-size.sm", "font-size.md", "font-weight.medium"
      ]
    },
    "Switch": {
      "kind": "compound",
      "base": "@base-ui/react/switch",
      "parts": {
        "Root": { "styled": true, "cssClass": "bl-switch" },
        "Thumb": { "styled": true, "cssClass": "bl-switch-thumb" }
      },
      "states": ["checked", "unchecked", "focus-visible", "disabled"],
      "tokens": [
        "color.border-strong", "color.accent", "color.bg",
        "space.4", "radius.full"
      ]
    },
    "Tabs": {
      "kind": "compound",
      "base": "@base-ui/react/tabs",
      "parts": {
        "Root": { "styled": true, "cssClass": "bl-tabs" },
        "List": { "styled": true, "cssClass": "bl-tabs-list" },
        "Tab": { "styled": true, "cssClass": "bl-tabs-tab" },
        "Panel": { "styled": true, "cssClass": "bl-tabs-panel" },
        "Indicator": { "styled": false }
      },
      "states": ["active", "hover", "focus-visible", "disabled"],
      "tokens": [
        "color.bg", "color.bg-subtle", "color.text", "color.text-muted",
        "color.accent", "space.1", "space.3", "radius.sm", "radius.md",
        "shadow.card", "font.sans", "font-size.sm", "font-weight.semibold"
      ]
    },
    "Accordion": {
      "kind": "compound",
      "base": "@base-ui/react/accordion",
      "parts": {
        "Root": { "styled": true, "cssClass": "bl-accordion" },
        "Item": { "styled": true, "cssClass": "bl-accordion-item" },
        "Header": { "styled": true, "cssClass": "bl-accordion-header" },
        "Trigger": { "styled": true, "cssClass": "bl-accordion-trigger" },
        "Panel": { "styled": true, "cssClass": "bl-accordion-panel" }
      },
      "states": ["open", "hover", "focus-visible", "disabled", "starting-style", "ending-style"],
      "tokens": [
        "color.bg-subtle", "color.text", "color.text-muted", "color.border",
        "color.accent", "space.2", "space.3", "space.4",
        "font.sans", "font-size.md", "font-weight.semibold"
      ]
    },
    "Progress": {
      "kind": "compound",
      "base": "@base-ui/react/progress",
      "parts": {
        "Root": { "styled": true, "cssClass": "bl-progress" },
        "Track": { "styled": true, "cssClass": "bl-progress-track" },
        "Indicator": { "styled": true, "cssClass": "bl-progress-indicator" },
        "Label": { "styled": false },
        "Value": { "styled": false }
      },
      "props": {
        "variant": {
          "values": ["default", "info", "success", "warning", "danger"],
          "default": "default",
          "dataAttribute": "data-bl-variant",
          "on": "Root"
        }
      },
      "states": ["progressing", "complete", "indeterminate"],
      "tokens": [
        "color.bg-subtle", "color.accent", "color.info-solid",
        "color.success-solid", "color.warning-solid", "color.danger",
        "radius.full"
      ]
    },
    "Card": {
      "kind": "single",
      "base": null,
      "cssClass": "bl-card",
      "props": {
        "padding": {
          "values": ["none", "sm", "md", "lg"],
          "default": "md",
          "dataAttribute": "data-bl-padding"
        },
        "interactive": {
          "values": [true, false],
          "default": false,
          "dataAttribute": "data-bl-interactive"
        }
      },
      "states": ["hover"],
      "tokens": [
        "color.bg", "color.border", "color.border-strong",
        "radius.lg", "shadow.card", "shadow.popup",
        "space.3", "space.4", "space.6"
      ]
    },
    "Text": {
      "kind": "single",
      "base": null,
      "cssClass": "bl-text",
      "props": {
        "variant": {
          "values": ["h1", "h2", "h3", "h4", "body-sm", "body-md", "body-lg", "muted-sm", "muted-md"],
          "default": "body-md",
          "dataAttribute": "data-bl-variant"
        }
      },
      "states": [],
      "tokens": [
        "color.text", "color.text-muted", "font.sans",
        "font-size.xs", "font-size.md", "font-size.lg", "font-size.xl", "font-size.2xl",
        "font-weight.medium", "font-weight.semibold", "font-weight.bold"
      ]
    },
    "Badge": {
      "kind": "single",
      "base": null,
      "cssClass": "bl-badge",
      "props": {
        "variant": {
          "values": ["gray", "blue", "green", "orange", "red", "purple", "pink"],
          "default": "gray",
          "dataAttribute": "data-bl-variant"
        }
      },
      "states": [],
      "tokens": [
        "color.bg-subtle", "color.text-muted", "color.border",
        "color.info-soft-bg", "color.info-soft-text", "color.info-soft-border",
        "color.success-soft-bg", "color.success-soft-text", "color.success-soft-border",
        "color.warning-soft-bg", "color.warning-soft-text", "color.warning-soft-border",
        "color.danger-soft-bg", "color.danger-soft-text", "color.danger-soft-border",
        "color.purple-soft-bg", "color.purple-soft-text", "color.purple-soft-border",
        "color.pink-soft-bg", "color.pink-soft-text", "color.pink-soft-border",
        "space.1", "space.2", "radius.sm", "font.sans", "font-size.xs", "font-weight.medium"
      ]
    },
    "Alert": {
      "kind": "single",
      "base": null,
      "cssClass": "bl-alert",
      "props": {
        "variant": {
          "values": ["info", "success", "warning", "danger"],
          "default": "info",
          "dataAttribute": "data-bl-variant"
        }
      },
      "states": [],
      "tokens": [
        "color.info-soft-bg", "color.info-soft-text", "color.info-soft-border",
        "color.success-soft-bg", "color.success-soft-text", "color.success-soft-border",
        "color.warning-soft-bg", "color.warning-soft-text", "color.warning-soft-border",
        "color.danger-soft-bg", "color.danger-soft-text", "color.danger-soft-border",
        "space.1", "space.2", "space.3", "space.4", "radius.md",
