{
  "name": "baseline-ui",
  "version": "0.1.0",
  "private": false,
  "description": "Design system do ecossistema — Base UI como motor de comportamento, tokens W3C como fonte única, manifest pronto para a ponte com o Figma.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "tokens",
    "baseline.manifest.json"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "tokens": "node scripts/build-tokens.mjs",
    "check-manifest": "node scripts/check-manifest.mjs",
    "build": "npm run tokens && npm run check-manifest && tsup",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^17 || ^18 || ^19",
    "react-dom": "^17 || ^18 || ^19"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "^19",
    "react-dom": "^19",
    "tsup": "^8",
    "typescript": "^5"
  }
}
