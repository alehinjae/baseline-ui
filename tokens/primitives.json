{
  "$description": "Camada 1 — primitivos. Valores brutos, sem significado de uso. Nenhum componente consome daqui diretamente; só a camada semântica referencia. No Figma, vira a coleção de Variables 'Primitives' (modo único). Paleta zinc/red herdada do Tailwind — proveniência documentada no ADR 0004. Os matizes de status/categoria (blue, green, orange, purple, pink) entraram na fase 2 (ADR 0007) com 6 paradas cada: 50/200 (fundos e bordas suaves no claro), 400 (texto/preenchimento no escuro), 600/700 (preenchimento/texto no claro), 950 (fundo suave no escuro).",
  "color": {
    "$type": "color",
    "white": { "$value": "#ffffff" },
    "black": { "$value": "#000000" },
    "zinc": {
      "50": { "$value": "#fafafa" },
      "100": { "$value": "#f4f4f5" },
      "200": { "$value": "#e4e4e7" },
      "300": { "$value": "#d4d4d8" },
      "400": { "$value": "#a1a1aa" },
      "500": { "$value": "#71717a" },
      "600": { "$value": "#52525b" },
      "700": { "$value": "#3f3f46" },
      "800": { "$value": "#27272a" },
      "900": { "$value": "#18181b" },
      "950": { "$value": "#09090b" }
    },
    "red": {
      "50": { "$value": "#fef2f2" },
      "200": { "$value": "#fecaca" },
      "400": { "$value": "#f87171" },
      "500": { "$value": "#ef4444" },
      "600": { "$value": "#dc2626" },
      "700": { "$value": "#b91c1c" },
      "950": { "$value": "#450a0a" }
    },
    "blue": {
      "50": { "$value": "#eff6ff" },
      "200": { "$value": "#bfdbfe" },
      "400": { "$value": "#60a5fa" },
      "600": { "$value": "#2563eb" },
      "700": { "$value": "#1d4ed8" },
      "950": { "$value": "#172554" }
    },
    "green": {
      "50": { "$value": "#f0fdf4" },
      "200": { "$value": "#bbf7d0" },
      "400": { "$value": "#4ade80" },
      "600": { "$value": "#16a34a" },
      "700": { "$value": "#15803d" },
      "950": { "$value": "#052e16" }
    },
    "orange": {
      "50": { "$value": "#fff7ed" },
      "200": { "$value": "#fed7aa" },
      "400": { "$value": "#fb923c" },
      "600": { "$value": "#ea580c" },
      "700": { "$value": "#c2410c" },
      "950": { "$value": "#431407" }
    },
    "purple": {
      "50": { "$value": "#faf5ff" },
      "200": { "$value": "#e9d5ff" },
      "400": { "$value": "#c084fc" },
      "600": { "$value": "#9333ea" },
      "700": { "$value": "#7e22ce" },
      "950": { "$value": "#3b0764" }
    },
    "pink": {
      "50": { "$value": "#fdf2f8" },
      "200": { "$value": "#fbcfe8" },
      "400": { "$value": "#f472b6" },
      "600": { "$value": "#db2777" },
      "700": { "$value": "#be185d" },
      "950": { "$value": "#500724" }
    }
  },
  "space": {
    "$type": "dimension",
    "1": { "$value": "4px" },
    "2": { "$value": "8px" },
    "3": { "$value": "12px" },
    "4": { "$value": "16px" },
    "5": { "$value": "24px" },
    "6": { "$value": "32px" },
    "7": { "$value": "40px" }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": "6px" },
    "md": { "$value": "10px" },
    "lg": { "$value": "16px" },
    "full": { "$value": "9999px" }
  },
  "font": {
    "sans": {
      "$type": "fontFamily",
      "$value": ["-apple-system", "BlinkMacSystemFont", "Segoe UI", "system-ui", "sans-serif"]
    }
  },
  "font-size": {
    "$type": "dimension",
    "xs": { "$value": "12px" },
    "sm": { "$value": "13px" },
    "md": { "$value": "14px" },
    "lg": { "$value": "16px" },
    "xl": { "$value": "18px" },
    "2xl": { "$value": "24px" }
  },
  "font-weight": {
    "$type": "fontWeight",
    "regular": { "$value": 400 },
    "medium": { "$value": 500 },
    "semibold": { "$value": 600 },
    "bold": { "$value": 700 }
  },
  "shadow": {
    "card": {
      "$type": "shadow",
      "$value": [
        { "offsetX": "0px", "offsetY": "1px", "blur": "2px", "spread": "0px", "color": "#0000000d" }
      ]
    },
    "popup": {
      "$type": "shadow",
      "$value": [
        { "offsetX": "0px", "offsetY": "10px", "blur": "38px", "spread": "-10px", "color": "#00000040" },
        { "offsetX": "0px", "offsetY": "10px", "blur": "20px", "spread": "-15px", "color": "#00000033" }
      ]
    }
  }
}
