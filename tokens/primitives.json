{
  "$description": "Camada 1 — primitivos. Valores brutos, sem significado de uso. Nenhum componente consome daqui diretamente; só a camada semântica referencia. No Figma, vira a coleção de Variables 'Primitives' (modo único). Paleta zinc/red herdada do Tailwind — proveniência documentada no ADR 0004.",
  "color": {
    "$type": "color",
    "white": { "$value": "#ffffff" },
    "black": { "$value": "#000000" },
    "zinc": {
      "50": { "$value": "#fafafa" },
      "100": { "$value": "#f4f4f5" },
      "200": { "$value": "#e4e4e7" },
      "300": { "$value": "#d4d4d8" },
      "400": { "$value": "#a1a1aa" },
      "500": { "$value": "#71717a" },
      "600": { "$value": "#52525b" },
      "700": { "$value": "#3f3f46" },
      "800": { "$value": "#27272a" },
      "900": { "$value": "#18181b" },
      "950": { "$value": "#09090b" }
    },
    "red": {
      "400": { "$value": "#f87171" },
      "500": { "$value": "#ef4444" },
      "600": { "$value": "#dc2626" }
    }
  },
  "space": {
    "$type": "dimension",
    "1": { "$value": "4px" },
    "2": { "$value": "8px" },
    "3": { "$value": "12px" },
    "4": { "$value": "16px" },
    "5": { "$value": "24px" }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": "6px" },
    "md": { "$value": "10px" },
    "lg": { "$value": "16px" },
    "full": { "$value": "9999px" }
  },
  "font": {
    "sans": {
      "$type": "fontFamily",
      "$value": ["-apple-system", "BlinkMacSystemFont", "Segoe UI", "system-ui", "sans-serif"]
    }
  },
  "font-size": {
    "$type": "dimension",
    "sm": { "$value": "13px" },
    "md": { "$value": "14px" },
    "lg": { "$value": "16px" }
  },
  "font-weight": {
    "$type": "fontWeight",
    "regular": { "$value": 400 },
    "medium": { "$value": 500 },
    "semibold": { "$value": 600 }
  },
  "shadow": {
    "popup": {
      "$type": "shadow",
      "$value": [
        { "offsetX": "0px", "offsetY": "10px", "blur": "38px", "spread": "-10px", "color": "#00000040" },
        { "offsetX": "0px", "offsetY": "10px", "blur": "20px", "spread": "-15px", "color": "#00000033" }
      ]
    }
  }
}
